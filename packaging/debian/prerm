#!/bin/sh
# prerm for p2ptunnel: stop the services cleanly (SIGTERM via systemctl stop,
# which the daemons handle as a graceful shutdown — see docs/SYSTEMD.md)
# before the package's files are removed, on both plain removal and upgrade.
set -e

case "$1" in
  remove|upgrade|deconfigure)
    if [ -d /run/systemd/system ]; then
      for unit in p2p-offer.service p2p-answer.service; do
        if systemctl is-active --quiet "$unit" 2>/dev/null; then
          systemctl stop "$unit"
        fi
      done
    fi
    ;;
esac

exit 0
