#!/bin/sh
# postinst for p2ptunnel.
#
# Idempotent: creates the service account, config directories, and
# state/log directories only if they don't already exist, so re-running
# this (a package upgrade re-invokes postinst) never overwrites an
# existing config directory's contents, private identity files, or state.
set -e

SERVICE_USER=p2ptunnel
SERVICE_GROUP=p2ptunnel

case "$1" in
  configure)
    if ! getent group "$SERVICE_GROUP" >/dev/null 2>&1; then
      addgroup --system "$SERVICE_GROUP"
    fi
    if ! getent passwd "$SERVICE_USER" >/dev/null 2>&1; then
      adduser --system --ingroup "$SERVICE_GROUP" --no-create-home \
        --home /nonexistent --shell /usr/sbin/nologin "$SERVICE_USER"
    fi

    for role in offer answer; do
      config_dir="/etc/p2ptunnel/$role"
      if [ ! -d "$config_dir" ]; then
        install -d -m 0750 -o root -g "$SERVICE_GROUP" "$config_dir"
      fi
      state_dir="/var/lib/p2ptunnel-$role"
      if [ ! -d "$state_dir" ]; then
        install -d -m 0750 -o "$SERVICE_USER" -g "$SERVICE_GROUP" "$state_dir"
      fi
      log_dir="/var/log/p2ptunnel-$role"
      if [ ! -d "$log_dir" ]; then
        install -d -m 0750 -o "$SERVICE_USER" -g "$SERVICE_GROUP" "$log_dir"
      fi
    done

    if [ -d /run/systemd/system ]; then
      systemctl daemon-reload

      # Bring a service that was active before this upgrade back up on the new
      # binary. try-restart only affects units that are already active, so a
      # first install (nothing active yet) never gets auto-started here. A
      # restart failure is not swallowed: with `set -e` active and no `|| true`,
      # it fails this script (and therefore the upgrade) visibly.
      for unit in p2p-offer.service p2p-answer.service; do
        if systemctl is-active --quiet "$unit" 2>/dev/null; then
          systemctl try-restart "$unit"
        fi
      done
    fi

    echo "p2ptunnel installed. This package does not create a default config."
    echo "Next steps:"
    echo "  1. Populate /etc/p2ptunnel/offer/{config.toml,identity,authorized_keys}"
    echo "     and the /etc/p2ptunnel/answer/ equivalent (see /usr/share/doc/p2ptunnel/)."
    echo "  2. p2pctl check-config --config /etc/p2ptunnel/offer/config.toml"
    echo "  3. systemctl enable --now p2p-offer.service p2p-answer.service"
    ;;
esac

exit 0
